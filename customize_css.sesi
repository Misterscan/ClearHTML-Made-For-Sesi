// customize_css.sesi
// Generate a customized CSS stylesheet using `model()` based on a short style description.
//
// Usage:
//   npm run sesi customize_css.sesi                                   # no style (uses default)
//   npm run sesi customize_css.sesi "dark editorial, serif headings"  # inline style arg

print "Customize CSS — generating CSS for a specific website"
print ""

let readMe = read_file("SPECIFICATION.md")
// Example CHTML and HTML output for the model to reference when generating CSS
// Replace with your own examples as needed. The more relevant the examples, the better the generated CSS will match your needs.
let chtmlExample = read_file("src/index.chtml")
let htmlOutputExample = read_file("out/index.html")

// Pass your style description as the first CLI argument, e.g.:
//   npm run sesi customize_css.sesi "warm neutrals, generous whitespace, serif headings"
// If no argument is provided the model uses its own defaults.
let style = ""
if len(args) > 0 {
  style = args[0]
}

if len(style) > 0 {
  print "Style description:" 
  print style
} else {
  let styleDefault = "Beautiful, premium modern UX design. Colors: Dynamic sky blues, dandelion yellows, and tangerine oranges, soft ambient background gradients. Dark mode (charcoal backgrounds, light text) with vibrant accent colors. Rounded corners and subtle shadows for depth. A polished and visually engaging style that elevates the user experience."
  print "No style provided, using default:"
  print styleDefault
  style = styleDefault
}
let examples = "CHTML Example: " + chtmlExample + "\n\n" + "HTML Output Example: " + htmlOutputExample
prompt need {"Spacing: Moderate padding and margins. Type scale: Base font size 16px, with clear hierarchy for headings. Overall style: " style " Target elements: body, header, nav, main-content, .content-section, links, buttons. Focus on readability, mobile responsiveness, and a cohesive visual design. Interactive elements (links, buttons) should have subtle hover effects."}
print ""
print "CSS Prompt:" 
print to_json(need)
print ""
let instruction = "You are a CSS generator. Produce a complete, valid CSS stylesheet that implements the user's need. Use CSS custom properties under :root when appropriate (colors, spacing, type scale). Target common page elements (body, header, nav, main-content, .content-section, links, buttons). The stylesheet should be compatible with ClearHTML structure ```markdown\n" + readMe + "\n```" + " and use CSS custom properties for easy theming. IMPORTANT: Don't forget to include the `background-clip` property. Output ONLY the raw CSS content with no explanations, no ```css backticks, or extra text."

print "Requesting CSS from model..."

// Change the model and parameters as needed. gemini-3-flash-preview is a good choice for code generation tasks, but feel free to experiment with other models or settings.
// gemini-3.5-flash for higher quality but token hungry, or gemini-3.1-pro-preview for a more polished and refined output.
// Both may take slightly longer than gemini-3-flash-preview, but can produce higher quality CSS with better adherence to best practices and design principles.
// Note: We set cache: false to ensure we get a fresh response each time, which is important during development when you may be iterating on the style description.
let css = model("gemini-3-flash-preview") {search, thinking_level: "low", max_tokens: 8192, cache: false} {instruction "User need: " need examples ". Only output CSS."}

print "Received CSS preview (first 6 lines):"
try {
  let lines = split(css, "\n")
  let n = len(lines)
  if n > 6 { n = 6 }
  for i = 0 to n - 1 { print lines[i] }
} catch (err) {
  print "  (preview failed):" err
}

print ""
print "Writing assets/generated.css..."
try {
  write_file("assets/generated.css", css)
  print "  ✓ assets/generated.css written"
} catch (err) {
  print "  ✗ Failed to write assets/generated.css:" err
}

print "Done. Review assets/generated.css and include it in your pages as needed."
